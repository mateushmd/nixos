{
    "layer": "top",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "bluetooth", "network", "battery"],
    "sway/window": {
        "max-length": 50
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¯╗¿",
        "format-icons": {
            "default": ["´ÇĞ", "´Çğ", "´Ç¿ "]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "¾░é▓",
